# ============================================================================
# TRAKT API - primary data source (trending, popular, box office, anticipated,
# search, genres, movie/show detail). Trakt is free for developers.
#
# HOW TO GET A CLIENT ID:
#   1. Create a free account at https://trakt.tv
#   2. Go to https://trakt.tv/oauth/applications and click "New Application"
#   3. Fill in any Name/Redirect URI (e.g. Redirect URI: urn:ietf:wg:oauth:2.0:oob)
#   4. Save, then copy the "Client ID" value shown on the application page
#   5. Paste it below as VITE_APP_TRAKT_CLIENT_ID
# ============================================================================
VITE_APP_TRAKT_API_URL=https://api.trakt.tv
VITE_APP_TRAKT_CLIENT_ID=your_trakt_client_id_here

# ============================================================================
# OMDb API - used ONLY to fetch a poster/backdrop image for a title, looked up
# by the IMDb ID that Trakt gives us. Trakt itself does not host any images.
#
# HOW TO GET A KEY:
#   1. Go to https://www.omdbapi.com/apikey.aspx
#   2. Choose the FREE tier, enter your email, and verify it
#   3. Paste the key you receive below as VITE_APP_OMDB_API_KEY
# ============================================================================
VITE_APP_OMDB_API_URL=https://www.omdbapi.com
VITE_APP_OMDB_API_KEY=your_omdb_api_key_here
